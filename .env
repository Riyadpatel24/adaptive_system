# ============================================================
# Adaptive System — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# SECURITY
# ----------------------------------------------------------
# Secret key used to authenticate API requests.
# Change this to a long random string before deploying!
API_KEY=330c7c4120fb13d4abf462a8f3630eb5a8bd92900c8a812bf847d8c9f62de21e

# ----------------------------------------------------------
# TELEMETRY
# Options: "synthetic" (fake data) | "real" (live metrics)
# ----------------------------------------------------------
TELEMETRY_MODE=synthetic

# ----------------------------------------------------------
# SIMULATION MODE
# true  → Actions are printed/logged only (safe for testing)
# false → Actions are actually executed (production)
# ----------------------------------------------------------
SIMULATION_MODE=false

# ----------------------------------------------------------
# ACTION COOLDOWN
# Seconds to wait before re-acting on the same entity
# ----------------------------------------------------------
ACTION_COOLDOWN_SECONDS=30

# ----------------------------------------------------------
# CHAOS ENGINEERING
# Enable to randomly inject CPU spikes and memory leaks
# for resilience testing. Keep false in production.
# ----------------------------------------------------------
CHAOS_ENABLED=false
CHAOS_INTERVAL_SECONDS=60

# ----------------------------------------------------------
# API SERVER
# ----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# ----------------------------------------------------------
# STORAGE PATHS (used inside Docker volume)
# ----------------------------------------------------------
DB_PATH=storage/events.db
MEMORY_PATH=storage/memory.json
